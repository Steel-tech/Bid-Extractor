{
  "manifest_version": 3,
  "name": "Bid Extractor",
  "version": "1.5.1",
  "description": "Matrix-themed bid extraction with priority scoring, dashboard stats, and digital rain animation. Extract RFQ data from Gmail, Outlook, BuildingConnected, PlanHub, Procore, SmartBidNet, PipelineSuite.",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*",
    "https://*.outlook.com/*",
    "https://*.buildingconnected.com/*",
    "https://app.buildingconnected.com/*",
    "https://*.planhub.com/*",
    "https://*.procore.com/*",
    "https://*.smartbidnet.com/*",
    "https://*.smartbid.co/*",
    "https://*.pipelinesuite.com/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["src/utils/config-loader.js", "src/utils/safe-query.js", "src/utils/shared-extractors.js", "src/content/email-parser.js", "src/content/gmail.js"],
      "css": ["src/content/content.css"]
    },
    {
      "matches": [
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*",
        "https://*.outlook.com/*"
      ],
      "js": ["src/utils/config-loader.js", "src/utils/safe-query.js", "src/utils/shared-extractors.js", "src/content/email-parser.js", "src/content/outlook.js"],
      "css": ["src/content/content.css"]
    },
    {
      "matches": [
        "https://*.buildingconnected.com/*",
        "https://app.buildingconnected.com/*"
      ],
      "js": ["src/utils/config-loader.js", "src/utils/safe-query.js", "src/utils/platform-helpers.js", "src/content/platforms/buildingconnected.js"]
    },
    {
      "matches": ["https://*.planhub.com/*"],
      "js": ["src/utils/config-loader.js", "src/utils/safe-query.js", "src/utils/platform-helpers.js", "src/content/platforms/planhub.js"]
    },
    {
      "matches": ["https://*.procore.com/*"],
      "js": ["src/utils/config-loader.js", "src/utils/safe-query.js", "src/utils/platform-helpers.js", "src/content/platforms/procore.js"]
    },
    {
      "matches": ["https://*.smartbidnet.com/*", "https://*.smartbid.co/*"],
      "js": ["src/utils/config-loader.js", "src/utils/safe-query.js", "src/utils/platform-helpers.js", "src/content/platforms/smartbidnet.js"]
    },
    {
      "matches": ["https://*.pipelinesuite.com/*"],
      "js": ["src/utils/config-loader.js", "src/utils/safe-query.js", "src/utils/platform-helpers.js", "src/content/platforms/pipelinesuite.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/config/gc-list.json",
        "src/config/keywords.json",
        "src/config/priority-weights.json",
        "src/config/selectors.json",
        "src/config/platforms.json",
        "src/config/blueprint-settings.json",
        "src/utils/config-loader.js",
        "src/utils/safe-query.js",
        "src/utils/shared-extractors.js",
        "src/utils/platform-helpers.js"
      ],
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*",
        "https://*.outlook.com/*",
        "https://*.buildingconnected.com/*",
        "https://app.buildingconnected.com/*",
        "https://*.planhub.com/*",
        "https://*.procore.com/*",
        "https://*.smartbidnet.com/*",
        "https://*.smartbid.co/*",
        "https://*.pipelinesuite.com/*"
      ]
    },
    {
      "resources": [
        "src/blueprint/ocr-service.js",
        "src/blueprint/annotations.js",
        "src/blueprint/member-detector.js",
        "src/blueprint/steel-database.js",
        "src/blueprint/takeoff.js",
        "src/blueprint/viewer.css",
        "src/blueprint/viewer.html",
        "src/blueprint/viewer.js",
        "src/lib/pdf.min.js",
        "src/lib/pdf.worker.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
